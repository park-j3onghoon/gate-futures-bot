# Gate.io API 자격증명 — 실제 사용 시 이 파일을 .env로 복사하고 값 채우기.
# python/.env 는 .gitignore에 등록돼서 커밋되지 않음.
GATE_API_KEY=
GATE_API_SECRET=

# host (생략 시 mainnet)
# GATE_API_HOST=https://api.gateio.ws/api/v4
# GATE_API_HOST=https://fx-api-testnet.gateio.ws/api/v4

# settle currency (생략 시 usdt)
# GATE_SETTLE=usdt
